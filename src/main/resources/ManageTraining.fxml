<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.ManageTrainingController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #f8fafc;">

    <!-- HEADER avec dégradé et ombre comme dans le design précédent -->
    <top>
        <HBox style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-background-radius: 0 0 20 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-padding: 20 30;"
              spacing="20" alignment="CENTER_LEFT">
            <Label text="🎓" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
            <VBox spacing="5">
                <Label text="INTEGRA – Gestion des Formations"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';" />
                <Label text="Administrateur / Module RH"
                       style="-fx-font-size: 12; -fx-text-fill: #b0c4de; -fx-font-family: 'Segoe UI';" />
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Label utilisateur connecté -->
            <VBox alignment="CENTER_RIGHT" spacing="5">
                <Label fx:id="userNameLabel"
                       text="Utilisateur"
                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 20; -fx-padding: 5 15;"/>
            </VBox>

            <!-- Bouton retour Dashboard -->
            <Button text="🏠  Dashboard"
                    onAction="#handleGoToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 8 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>

            <!-- Bouton Déconnexion -->
            <Button text="↩ Déconnexion"
                    onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 8 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
        </HBox>
    </top>

    <!-- MAIN avec padding et espacement comme dans le design précédent -->
    <center>
        <HBox spacing="25" style="-fx-padding: 25 30;" VBox.vgrow="ALWAYS">

            <!-- LEFT: SKILLS - Carte style projet -->
            <VBox spacing="15" prefWidth="340" minWidth="300"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">

                <!-- Skills Header -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🎯" style="-fx-font-size: 24px;"/>
                    <VBox spacing="1">
                        <Label text="Skills"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold';"/>
                        <Label text="Available skills for training"
                               style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                    </VBox>
                </HBox>

                <!-- Search + Filter -->
                <VBox spacing="10">
                    <TextField fx:id="searchSkillField" promptText="🔍 Search by name or category..."
                               style="-fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #dbeafe; -fx-background-color: white; -fx-padding: 8 15; -fx-font-size: 13px;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Category:" style="-fx-font-size: 13px; -fx-text-fill: #1e3a5f; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="filterCategoryCombo" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  promptText="All categories"
                                  style="-fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #dbeafe; -fx-background-color: white; -fx-padding: 5 10;"/>
                    </HBox>
                </VBox>

                <!-- En-tête de colonnes pour Skills -->
                <HBox spacing="10" style="-fx-padding: 5 0 5 0; -fx-border-color: #dbeafe; -fx-border-width: 0 0 1 0;">
                    <Label text="ID" prefWidth="60" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Skill Name" prefWidth="110" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Level" prefWidth="90" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Category" prefWidth="95" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                </HBox>

                <!-- Skills Table -->
                <TableView fx:id="skillsTable" VBox.vgrow="ALWAYS" prefHeight="300"
                           style="-fx-background-color: transparent; -fx-border-color: #dbeafe; -fx-border-width: 1; -fx-border-radius: 15; -fx-background-insets: 0;">
                    <columns>
                        <TableColumn fx:id="skillIdColumn"       text="Skill ID"   prefWidth="60"/>
                        <TableColumn fx:id="skillNameColumn"     text="Skill Name"  prefWidth="110"/>
                        <TableColumn fx:id="skillLevelColumn"    text="Level"      prefWidth="90"/>
                        <TableColumn fx:id="skillCategoryColumn" text="Category"   prefWidth="95"/>
                    </columns>
                    <placeholder>
                        <Label text="No skills found"
                               style="-fx-text-fill: #6b7280; -fx-font-style: italic;"/>
                    </placeholder>
                </TableView>

                <!-- Boutons d'action pour Skills -->
                <HBox spacing="10">
                    <Button text="＋ Add Skill" onAction="#handleAddSkill"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
                    <Button text="✏ Edit" onAction="#handleEditSkill"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
                </HBox>

                <Button text="🗑 Delete Skill" onAction="#handleDeleteSkill"
                        maxWidth="Infinity"
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>

            </VBox>

            <!-- RIGHT PANEL -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">

                <!-- Training Programs Header -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🎓" style="-fx-font-size: 24px;"/>
                        <VBox spacing="1">
                            <Label text="Training Programs"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0b5e42; -fx-font-family: 'Segoe UI Semibold';"/>
                            <Label text="Available training programs"
                                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Selection label -->
                <Label fx:id="selectionLabel" text="📋 All training programs"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-padding: 0 5;"/>

                <!-- En-tête de colonnes pour Trainings -->
                <HBox spacing="10" style="-fx-padding: 5 0 5 0; -fx-border-color: #c7f9e9; -fx-border-width: 0 0 1 0;">
                    <Label text="Training ID" prefWidth="90" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Program Name" prefWidth="220" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Duration" prefWidth="80" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Skill Covered" prefWidth="140" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Type" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Status" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                </HBox>

                <!-- Trainings Table -->
                <TableView fx:id="trainingsTable" VBox.vgrow="ALWAYS" minHeight="300"
                           style="-fx-background-color: transparent; -fx-border-color: #c7f9e9; -fx-border-width: 1; -fx-border-radius: 15; -fx-background-insets: 0;">
                    <columns>
                        <TableColumn fx:id="trainingIdColumn"       text="Training ID"   prefWidth="90"/>
                        <TableColumn fx:id="trainingNameColumn"     text="Program Name"  prefWidth="220"/>
                        <TableColumn fx:id="trainingDurationColumn" text="Duration"      prefWidth="80"/>
                        <TableColumn fx:id="trainingSkillColumn"    text="Skill Covered" prefWidth="140"/>
                        <TableColumn fx:id="trainingTypeColumn"     text="Type"          prefWidth="100"/>
                        <TableColumn fx:id="trainingStatusColumn"   text="Status"        prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="No training programs found"
                               style="-fx-text-fill: #6b7280; -fx-font-style: italic;"/>
                    </placeholder>
                </TableView>

                <!-- DETAILS + ACTIONS -->
                <HBox spacing="15" minHeight="200">

                    <!-- Program Info Card - Style dégradé comme dans le design précédent -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: linear-gradient(to bottom right, #ffffff, #f9fcff); -fx-background-radius: 20; -fx-border-color: #d9e2ef; -fx-border-width: 1; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,50,100,0.1), 20, 0, 0, 10); -fx-padding: 20;">

                        <Label text="📋 Training Details"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold'; -fx-border-width: 0 0 2 0; -fx-border-color: #b0c4de; -fx-padding: 0 0 10 0;"/>

                        <GridPane hgap="20" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="100"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints minWidth="80"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Program Name:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="detailNameLabel" text="—"
                                   style="-fx-text-fill: #0f172a; -fx-font-size: 13; -fx-background-color: #f1f9ff; -fx-padding: 5 10; -fx-background-radius: 8;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Duration:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13;" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <Label fx:id="detailDurationLabel" text="—"
                                   style="-fx-text-fill: #0f172a; -fx-font-size: 13; -fx-background-color: #eef2ff; -fx-padding: 5 10; -fx-background-radius: 8;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Trainer:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="detailTrainerLabel" text="—"
                                   style="-fx-text-fill: #0f172a; -fx-font-size: 13; -fx-background-color: #eef2ff; -fx-padding: 5 10; -fx-background-radius: 8;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Skill Targeted:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13;" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <Label fx:id="detailSkillLabel" text="—"
                                   style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 8; -fx-font-weight: bold; -fx-font-size: 12px;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Description:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="detailDescriptionLabel" text="—" wrapText="true"
                                   style="-fx-text-fill: #334155; -fx-font-size: 12; -fx-background-color: #f8fafc; -fx-padding: 8 12; -fx-background-radius: 8;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                            <Label text="Status:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="detailStatusLabel" text="—"
                                   style="-fx-text-fill: #0f172a; -fx-font-size: 13; -fx-background-color: #eef2ff; -fx-padding: 5 10; -fx-background-radius: 8;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- Actions Card - Style comme dans le design précédent -->
                    <VBox spacing="10" prefWidth="230"
                          style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f5f9ff); -fx-background-radius: 20; -fx-border-color: #d9e2ef; -fx-border-width: 1; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 20;">

                        <Label text="⚡ Quick Actions"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold'; -fx-border-width: 0 0 1 0; -fx-border-color: #b0c4de; -fx-padding: 0 0 10 0;"/>

                        <Label text="── Training ──"
                               style="-fx-font-size: 11px; -fx-text-fill: #6b7280; -fx-alignment: center;"/>

                        <Button text="＋ Add Training Program" onAction="#handleAddTraining"
                                maxWidth="Infinity"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12; -fx-background-radius: 30; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>

                        <Button text="🔄 Update Training" onAction="#handleUpdateTraining"
                                maxWidth="Infinity"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12; -fx-background-radius: 30; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>

                        <Button text="🗑 Delete Training" onAction="#handleDeleteTraining"
                                maxWidth="Infinity"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12; -fx-background-radius: 30; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>

                        <Label text="── Association ──"
                               style="-fx-font-size: 11px; -fx-text-fill: #6b7280; -fx-alignment: center; -fx-padding: 5 0 0 0;"/>

                        <Button text="🔗 Assign Skill" onAction="#handleAssignSkill"
                                maxWidth="Infinity"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12; -fx-background-radius: 30; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <!-- FOOTER - Style comme dans le design précédent -->
    <bottom>
        <HBox style="-fx-background-color: linear-gradient(to right, #e2eaf8, #d4e0f0); -fx-padding: 12 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" alignment="CENTER_LEFT">
            <Label fx:id="footerLabel" text="🔌 Connected • Database: INTEGRA_DB • Training Management Module"
                   style="-fx-text-fill: #1e3a5f; -fx-font-size: 12px; -fx-font-family: 'Segoe UI'; -fx-font-weight: 500;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="INTEGRA HR Management System © 2026"
                   style="-fx-text-fill: #1e3a5f; -fx-font-size: 11px; -fx-font-weight: 500;"/>
        </HBox>
    </bottom>

</BorderPane>