<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.UserTrainingProgramListController"
            prefWidth="900" prefHeight="620"
            style="-fx-background-color: #f8fafc;">

    <!-- HEADER avec dégradé et ombre comme dans le design précédent -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-background-radius: 0 0 20 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-padding: 20 25;">

            <Label text="🎓" style="-fx-font-size: 28px; -fx-text-fill: white;"/>

            <VBox spacing="5">
                <Label text="INTEGRA — Mes Formations"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';" />
                <Label fx:id="welcomeLabel" text="👤 Bienvenue"
                       style="-fx-font-size: 12; -fx-text-fill: #b0c4de; -fx-font-family: 'Segoe UI';"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Bouton retour Dashboard -->
            <Button text="🏠  Dashboard" onAction="#handleGoToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 8 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>

            <!-- Bouton Logout -->
            <Button text="⎋  Logout" onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 8 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
        </HBox>
    </top>

    <!-- CONTENU avec style de carte -->
    <center>
        <VBox spacing="20" style="-fx-padding: 25 30;">

            <!-- Barre recherche + bouton dans une carte -->
            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🔍" style="-fx-font-size: 20px;"/>
                    <VBox spacing="1">
                        <Label text="Recherche de formations"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold';"/>
                        <Label text="Trouvez rapidement la formation qui vous intéresse"
                               style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="🔍  Rechercher une formation par nom..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #dbeafe; -fx-background-color: white; -fx-padding: 10 15; -fx-font-size: 13px;"/>
                    <Button text="👁  Voir Détails" onAction="#handleViewDetail"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 25; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                </HBox>

                <Label text="💡 Double-cliquez sur une formation pour voir les détails"
                       style="-fx-font-size: 11px; -fx-text-fill: #6b7280; -fx-font-style: italic; -fx-padding: 5 0 0 5;"/>
            </VBox>

            <!-- Carte pour la table des formations -->
            <VBox spacing="12" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📋" style="-fx-font-size: 20px;"/>
                    <VBox spacing="1">
                        <Label text="Liste des formations disponibles"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold';"/>
                        <Label text="Programmes de formation assignés à votre profil"
                               style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <!-- En-tête de colonnes -->
                <HBox spacing="10" style="-fx-padding: 10 0 5 0; -fx-border-color: #dbeafe; -fx-border-width: 0 0 1 0;">
                    <Label text="ID" prefWidth="65" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Formation" prefWidth="310" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Durée" prefWidth="80" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Type" prefWidth="110" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Statut" prefWidth="110" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Quiz" prefWidth="110" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                </HBox>

                <!-- Table formations -->
                <TableView fx:id="trainingsTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: #dbeafe; -fx-border-width: 1; -fx-border-radius: 15; -fx-background-insets: 0;">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID"        prefWidth="65"/>
                        <TableColumn fx:id="colTitle"    text="Formation"  prefWidth="310"/>
                        <TableColumn fx:id="colDuration" text="Durée"     prefWidth="80"/>
                        <TableColumn fx:id="colType"     text="Type"      prefWidth="110"/>
                        <TableColumn fx:id="colStatus"   text="Statut"    prefWidth="110"/>
                        <TableColumn fx:id="colQuiz"     text="Quiz"      prefWidth="110"/>
                    </columns>
                    <placeholder>
                        <Label text="📭 Aucune formation disponible"
                               style="-fx-text-fill: #6b7280; -fx-font-style: italic; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

    <!-- FOOTER avec style du design précédent -->
    <bottom>
        <HBox style="-fx-background-color: linear-gradient(to right, #e2eaf8, #d4e0f0); -fx-padding: 12 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" alignment="CENTER_LEFT">
            <Label fx:id="footerLabel" text="🔌 Connecté • INTEGRA HR • Mes formations"
                   style="-fx-text-fill: #1e3a5f; -fx-font-size: 12px; -fx-font-family: 'Segoe UI'; -fx-font-weight: 500;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="INTEGRA HR Management System © 2026"
                   style="-fx-text-fill: #1e3a5f; -fx-font-size: 11px; -fx-font-weight: 500;"/>
        </HBox>
    </bottom>

</BorderPane>