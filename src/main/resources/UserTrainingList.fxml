<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.UserTrainingProgramListController"
            prefWidth="900" prefHeight="620"
            style="-fx-background-color: #f0f2f5;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: linear-gradient(to right, #1565c0, #1976d2); -fx-padding: 12 20;">
            <Label text="🎓" style="-fx-font-size: 26px;"/>
            <VBox spacing="1">
                <Label text="INTEGRA — Mes Formations"
                       style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                <Label fx:id="welcomeLabel" text="👤 Bienvenue"
                       style="-fx-text-fill: #90caf9; -fx-font-size: 11px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Bouton retour Dashboard -->
            <Button text="🏠  Dashboard" onAction="#handleGoToDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 16;
                           -fx-background-radius: 6; -fx-cursor: hand;"/>

            <!-- Bouton Logout -->
            <Button text="⎋  Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e53935; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 16;
                           -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- CONTENU -->
    <center>
        <VBox spacing="12" style="-fx-padding: 16;">

            <!-- Barre recherche + bouton -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="🔍  Rechercher une formation..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 6; -fx-border-color: #e0e0e0;
                                  -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                <Button text="👁  Voir Détails" onAction="#handleViewDetail"
                        style="-fx-background-color: #1976d2; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 9 18;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

            <Label text="💡 Double-cliquez sur une formation pour voir les détails"
                   style="-fx-font-size: 11px; -fx-text-fill: #90a4ae; -fx-font-style: italic;"/>

            <!-- Table formations -->
            <TableView fx:id="trainingsTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 8; -fx-border-color: transparent;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 2);">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"        prefWidth="65"/>
                    <TableColumn fx:id="colTitle"    text="Formation"  prefWidth="310"/>
                    <TableColumn fx:id="colDuration" text="Durée"     prefWidth="80"/>
                    <TableColumn fx:id="colType"     text="Type"      prefWidth="110"/>
                    <TableColumn fx:id="colStatus"   text="Statut"    prefWidth="110"/>
                    <TableColumn fx:id="colQuiz"     text="Quiz"      prefWidth="110"/>
                </columns>
                <placeholder>
                    <Label text="Aucune formation disponible"
                           style="-fx-text-fill: #90a4ae; -fx-font-style: italic;"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

    <!-- FOOTER -->
    <bottom>
        <HBox style="-fx-background-color: #263238; -fx-padding: 6 16;"
              alignment="CENTER_LEFT">
            <Label fx:id="footerLabel" text="INTEGRA HR"
                   style="-fx-text-fill: #90a4ae; -fx-font-size: 10px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="INTEGRA HR Management System © 2026"
                   style="-fx-text-fill: #546e7a; -fx-font-size: 10px;"/>
        </HBox>
    </bottom>

</BorderPane>
