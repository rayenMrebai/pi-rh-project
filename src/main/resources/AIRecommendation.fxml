<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.AIRecommendationController"
      prefWidth="820" prefHeight="620"
      style="-fx-background-color: #f0f4f8;">

    <!-- HEADER GRADIENT -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: linear-gradient(to right, #0b1e33, #0B63CE); -fx-padding: 20 28;">
        <Label text="🤖"
               style="-fx-font-size: 26;"/>
        <VBox spacing="2">
            <Label text="AI Resource Recommendation Engine"
                   style="-fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';"/>
            <Label fx:id="projectNameLabel" text="Project: —"
                   style="-fx-font-size: 12; -fx-text-fill: #90bfff; -fx-font-family: 'Segoe UI';"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusBadge" text="● READY"
               style="-fx-text-fill: #34d399; -fx-font-size: 12; -fx-font-weight: bold;"/>
    </HBox>

    <!-- PODIUM TOP 3 -->
    <HBox fx:id="podiumBox" alignment="BOTTOM_CENTER" spacing="16"
          style="-fx-background-color: linear-gradient(to bottom, #1e3a5f, #145493); -fx-padding: 18 28 20 28;">

        <!-- 2nd place -->
        <VBox fx:id="card2" alignment="CENTER" spacing="6" prefWidth="190"
              style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 14 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 4);">
            <Label text="🥈" style="-fx-font-size: 30;"/>
            <Label fx:id="name2" text="—"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';"/>
            <Label fx:id="role2" text="—"
                   style="-fx-font-size: 11; -fx-text-fill: #90bfff;"/>
            <Label fx:id="score2" text="—%"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #c0cfff;"/>
            <Label fx:id="alloc2" text="Alloc: —"
                   style="-fx-font-size: 11; -fx-text-fill: #6b9fd4;"/>
            <Button fx:id="assign2" text="Affecter"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 18; -fx-cursor: hand; -fx-font-size: 12;"/>
        </VBox>

        <!-- 1st place — plus grand -->
        <VBox fx:id="card1" alignment="CENTER" spacing="6" prefWidth="210"
              style="-fx-background-color: rgba(255,215,0,0.12); -fx-background-radius: 18; -fx-border-color: rgba(255,215,0,0.45); -fx-border-radius: 18; -fx-border-width: 2; -fx-padding: 18 12; -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.25), 18, 0, 0, 6);">
            <Label text="🥇" style="-fx-font-size: 38;"/>
            <Label fx:id="name1" text="—"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #fde68a; -fx-font-family: 'Segoe UI Semibold';"/>
            <Label fx:id="role1" text="—"
                   style="-fx-font-size: 12; -fx-text-fill: #fcd34d;"/>
            <Label fx:id="score1" text="—%"
                   style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #fde68a;"/>
            <Label fx:id="alloc1" text="Alloc: —"
                   style="-fx-font-size: 11; -fx-text-fill: #fcd34d;"/>
            <Button fx:id="assign1" text="⚡ Affecter"
                    style="-fx-background-color: linear-gradient(to right, #f59e0b, #d97706); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 22; -fx-cursor: hand; -fx-font-size: 13; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 5, 0, 0, 2);"/>
        </VBox>

        <!-- 3rd place -->
        <VBox fx:id="card3" alignment="CENTER" spacing="6" prefWidth="190"
              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 16; -fx-border-color: rgba(205,127,50,0.35); -fx-border-radius: 16; -fx-border-width: 1; -fx-padding: 14 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 4);">
            <Label text="🥉" style="-fx-font-size: 30;"/>
            <Label fx:id="name3" text="—"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';"/>
            <Label fx:id="role3" text="—"
                   style="-fx-font-size: 11; -fx-text-fill: #90bfff;"/>
            <Label fx:id="score3" text="—%"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #cd7f32;"/>
            <Label fx:id="alloc3" text="Alloc: —"
                   style="-fx-font-size: 11; -fx-text-fill: #6b9fd4;"/>
            <Button fx:id="assign3" text="Affecter"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 18; -fx-cursor: hand; -fx-font-size: 12;"/>
        </VBox>
    </HBox>

    <!-- TABLEAU COMPLET -->
    <VBox spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 0; -fx-padding: 18 24;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="📋 Tous les candidats"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold';"/>
            <Label fx:id="countLabel" text=""
                   style="-fx-font-size: 12; -fx-text-fill: #6b7280; -fx-background-color: #e2e8f0; -fx-padding: 2 10; -fx-background-radius: 20;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="analyzeButton" text="🔍  Lancer l'analyse IA"
                    style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 25; -fx-padding: 10 24; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 3);"/>
        </HBox>

        <!-- En-tête tableau -->
        <HBox spacing="0"
              style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 10 14;">
            <Label text="Rang" prefWidth="60"  style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
            <Label text="Employé" prefWidth="170" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
            <Label text="Rôle" prefWidth="160" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
            <Label text="Score IA" prefWidth="90"  style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
            <Label text="Dispo %" prefWidth="80"  style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
            <Label text="Score Final" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
            <Label text="Alloc. Suggérée" prefWidth="110" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
            <Label text="Action" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-size: 12;"/>
        </HBox>

        <ListView fx:id="resultsListView" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: transparent; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-insets: 0;"/>
    </VBox>

    <!-- FOOTER STATUS -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #e2e8f0; -fx-padding: 10 24;">
        <Label fx:id="footerLabel" text="Prêt — Sélectionnez un projet et lancez l'analyse."
               style="-fx-font-size: 12; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressBar fx:id="progressBar" prefWidth="180" prefHeight="8" progress="0"
                     style="-fx-accent: #0B63CE; -fx-background-color: #cbd5e1; -fx-background-radius: 5;"/>
    </HBox>
</VBox>