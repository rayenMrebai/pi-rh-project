<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.DashboardController"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;">
    <content>
        <VBox spacing="25" style="-fx-background-color: #f8fafc;">
            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-padding: 20 25;">
                <VBox spacing="5">
                    <Label text="INTEGRA – Manage HR Projects"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';" />
                    <Label text="Administrator / RH / Manager Module"
                           style="-fx-font-size: 12; -fx-text-fill: #b0c4de; -fx-font-family: 'Segoe UI';" />
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Add Project" fx:id="addProjectButton"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 24; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 3);"/>
            </HBox>

            <!-- Affichage des taux de change compact -->
            <HBox alignment="CENTER" spacing="0"
                  style="-fx-background-color: #f8fafc; -fx-background-radius: 40;
             -fx-border-color: #dbeafe; -fx-border-width: 1; -fx-border-radius: 40;
             -fx-padding: 4 6;">

                <!-- Icône taux -->
                <HBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: linear-gradient(to right, #0B63CE, #1a7de8); -fx-background-radius: 30; -fx-padding: 6 12;">
                    <Label text="💱" style="-fx-font-size: 14;"/>
                    <Label text="Taux" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 12;"/>
                </HBox>

                <!-- USD -->
                <HBox alignment="CENTER" spacing="4" style="-fx-padding: 6 12;">
                    <Label text="🇺🇸" style="-fx-font-size: 14;"/>
                    <Label fx:id="usdRateLabel" text="—" style="-fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-size: 13;"/>
                    <Label text="USD" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
                </HBox>

                <!-- Séparateur léger -->
                <Region prefWidth="1" prefHeight="16" style="-fx-background-color: #dbeafe;"/>

                <!-- EUR -->
                <HBox alignment="CENTER" spacing="4" style="-fx-padding: 6 12;">
                    <Label text="🇪🇺" style="-fx-font-size: 14;"/>
                    <Label fx:id="eurRateLabel" text="—" style="-fx-font-weight: bold; -fx-text-fill: #0FA36B; -fx-font-size: 13;"/>
                    <Label text="EUR" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
                </HBox>

                <!-- Badge live -->
                <HBox alignment="CENTER" spacing="3" style="-fx-background-color: #e2e8f0; -fx-background-radius: 20; -fx-padding: 4 10;">
                    <Label text="●" style="-fx-text-fill: #0FA36B; -fx-font-size: 10;"/>
                    <Label text="LIVE" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                </HBox>
            </HBox>

            <!-- PROJECTS LIST -->
            <VBox spacing="12" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📊 HR Projects" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold';"/>
                </HBox>
                <HBox spacing="10">
                    <TextField fx:id="searchProjectField" promptText="Search by name or ID..." HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #dbeafe; -fx-background-color: white; -fx-padding: 8 15;"/>
                    <ComboBox fx:id="statusFilterCombo" promptText="All statuses" prefWidth="150"
                              style="-fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #dbeafe; -fx-background-color: white; -fx-padding: 5 10;"/>
                </HBox>
                <HBox spacing="10" style="-fx-padding: 5 0 5 0; -fx-border-color: #dbeafe; -fx-border-width: 0 0 1 0;">
                    <Label text="Project ID" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Project Name" prefWidth="250" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Start Date" prefWidth="120" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="End Date" prefWidth="120" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                    <Label text="Status" prefWidth="140" style="-fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                </HBox>
                <ListView fx:id="projectsListView" VBox.vgrow="ALWAYS" prefHeight="200" minHeight="200"
                          style="-fx-background-color: transparent; -fx-border-color: #dbeafe; -fx-border-width: 1; -fx-border-radius: 15; -fx-background-insets: 0;">
                </ListView>
            </VBox>

            <!-- ASSIGNMENTS LIST -->
            <VBox spacing="12" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="👥 Project Assignments" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0b5e42; -fx-font-family: 'Segoe UI Semibold';"/>
                    <Label fx:id="selectedProjectLabel" text="Employees assigned to: (select a project)"
                           style="-fx-text-fill: #6b7280; -fx-font-size: 12; -fx-padding: 3 0 0 0;"/>
                </HBox>
                <TextField fx:id="searchAssignmentField" promptText="Search by role, ID or employee name..."
                           style="-fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #c7f9e9; -fx-background-color: white; -fx-padding: 8 15;"/>
                <HBox spacing="10" style="-fx-padding: 5 0 5 0; -fx-border-color: #c7f9e9; -fx-border-width: 0 0 1 0;">
                    <Label text="Assignment ID" prefWidth="110" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Employee Name" prefWidth="160" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Role" prefWidth="170" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Allocation %" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="Start" prefWidth="130" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                    <Label text="End" prefWidth="130" style="-fx-font-weight: bold; -fx-text-fill: #0b5e42;"/>
                </HBox>
                <ListView fx:id="assignmentsListView" VBox.vgrow="ALWAYS" prefHeight="200" minHeight="200"
                          style="-fx-background-color: transparent; -fx-border-color: #c7f9e9; -fx-border-width: 1; -fx-border-radius: 15; -fx-background-insets: 0;">
                </ListView>
            </VBox>

            <!-- PROJECT DETAILS + ACTIONS -->
            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <!-- Détails du projet -->
                <VBox spacing="15" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: linear-gradient(to bottom right, #ffffff, #f9fcff); -fx-background-radius: 20; -fx-border-color: #d9e2ef; -fx-border-width: 1; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,50,100,0.1), 20, 0, 0, 10); -fx-padding: 25;">
                    <Label text="📋 Project Details" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold'; -fx-border-width: 0 0 2 0; -fx-border-color: #b0c4de; -fx-padding: 0 0 10 0;"/>
                    <GridPane hgap="25" vgap="15" style="-fx-padding: 10 0 0 0;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="140"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="🏷️ Project Name:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 14;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="detailName" style="-fx-text-fill: #0f172a; -fx-font-size: 14; -fx-background-color: #f1f9ff; -fx-padding: 5 10; -fx-background-radius: 8;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="📝 Description:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 14;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="detailDescription" wrapText="true" style="-fx-text-fill: #334155; -fx-font-size: 13; -fx-background-color: #f8fafc; -fx-padding: 8 12; -fx-background-radius: 8;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="📅 Start Date:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 14;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="detailStart" style="-fx-text-fill: #0f172a; -fx-font-size: 14; -fx-background-color: #eef2ff; -fx-padding: 5 10; -fx-background-radius: 8;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="📆 End Date:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 14;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="detailEnd" style="-fx-text-fill: #0f172a; -fx-font-size: 14; -fx-background-color: #eef2ff; -fx-padding: 5 10; -fx-background-radius: 8;" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="⚙️ Status:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 14;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="detailStatus" style="-fx-text-fill: #0f172a; -fx-font-size: 14; -fx-background-color: #eef2ff; -fx-padding: 5 10; -fx-background-radius: 8;" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <!-- Budget avec bouton de conversion -->
                        <Label text="💰 Budget:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 14;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="5" GridPane.columnIndex="1">
                            <Label fx:id="detailBudget" style="-fx-text-fill: #0f172a; -fx-font-size: 14; -fx-background-color: #eef2ff; -fx-padding: 5 10; -fx-background-radius: 8;" />
                            <Label fx:id="detailBudgetCurrency" text="TND" style="-fx-text-fill: #0f172a; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 5 0;" />
                            <Button fx:id="budgetToggleButton" text="⇄" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-background-radius: 30; -fx-cursor: hand; -fx-padding: 5 15;"/>
                        </HBox>
                    </GridPane>
                </VBox>

                <!-- Actions -->
                <VBox spacing="15" minWidth="240" alignment="TOP_CENTER"
                      style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f5f9ff); -fx-background-radius: 20; -fx-border-color: #d9e2ef; -fx-border-width: 1; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 25 20;">
                    <Label text="⚡ Quick Actions" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold'; -fx-border-width: 0 0 1 0; -fx-border-color: #b0c4de; -fx-padding: 0 0 10 0;"/>

                    <Button text="✏️ Edit Project" fx:id="editProjectButton" maxWidth="Infinity"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="🗑️ Delete Project" fx:id="deleteProjectButton" maxWidth="Infinity"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="👤 Assign Employee" fx:id="assignEmployeeButton" maxWidth="Infinity"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="🔄 Update Assignment" fx:id="updateAssignmentButton" maxWidth="Infinity"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="❌ Remove Assignment" fx:id="removeAssignmentButton" maxWidth="Infinity"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <!-- PDF Export buttons -->
                    <Button text="📄 Exporter tout en PDF" fx:id="exportAllPdfButton" maxWidth="Infinity"
                            style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="📄 Exporter ce projet" fx:id="exportProjectPdfButton" maxWidth="Infinity"
                            style="-fx-background-color: #0FA36B; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <!-- EXCEL Export buttons -->
                    <Button text="📊 Exporter tout en Excel" fx:id="exportAllExcelButton" maxWidth="Infinity"
                            style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="📊 Exporter ce projet" fx:id="exportProjectExcelButton" maxWidth="Infinity"
                            style="-fx-background-color: #0FA36B; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="🧠 IA Assistant" fx:id="aiAssistantButton" maxWidth="Infinity"
                            style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                    <Button text="🤖 Recommandation IA" fx:id="aiRecommendButton" maxWidth="Infinity"
                            style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                </VBox>
            </HBox>

            <!-- STATUS BAR -->
            <HBox style="-fx-background-color: linear-gradient(to right, #e2eaf8, #d4e0f0); -fx-padding: 14 22; -fx-background-radius: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" alignment="CENTER_LEFT">
                <Label fx:id="statusLabel" text="🔌 Connected - Database: INTEGRA_DB • 6 active projects • 8 assignments loaded"
                       style="-fx-text-fill: #1e3a5f; -fx-font-size: 13; -fx-font-family: 'Segoe UI'; -fx-font-weight: 500;"/>
            </HBox>
        </VBox>
    </content>
</ScrollPane>