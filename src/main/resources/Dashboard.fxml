<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.DashboardController"
            stylesheets="@style.css"
            styleClass="theme-light"
            style="-fx-background-color: #f8fafc;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              styleClass="bg-primary"
              style="-fx-padding: 16 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 4);">
            <Label text="INTEGRA"
                   styleClass="text-white"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Semibold';"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userNameLabel"
                   styleClass="text-secondary"
                   style="-fx-font-size: 13;"/>
            <Button fx:id="logoutButton" text="🚪  Déconnexion"
                    styleClass="button-logout"
                    style="-fx-font-size: 13; -fx-padding: 8 20;"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar">
            <Button fx:id="navDashboard" text="🏠 Dashboard"/>
            <Button fx:id="navUsers" text="👥 Utilisateurs"/>
            <Button fx:id="navFormations" text="📚 Formations"/>
            <Button fx:id="navProjets" text="📁 Projets"/>
            <Button fx:id="navRecrutement" text="📋 Recrutement"/>
            <Button fx:id="navSalaire" text="💰 Salaire"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="24" styleClass="theme-light" style="-fx-background-color: #f8fafc;">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <Label text="🏠  Mon Tableau de Bord"
                   styleClass="title"
                   style="-fx-font-size: 26; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Semibold';"/>

            <VBox spacing="16"
                  styleClass="card"
                  style="-fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 28;">

                <Label text="👤  Informations du compte"
                       styleClass="card-title"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Semibold';"/>

                <GridPane hgap="24" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints minWidth="160" maxWidth="160"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Nom d'utilisateur" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           styleClass="label-bold"/>
                    <Label fx:id="usernameDisplay" GridPane.columnIndex="1" GridPane.rowIndex="0"
                           styleClass="value-bg"/>

                    <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           styleClass="label-bold"/>
                    <Label fx:id="emailDisplay" GridPane.columnIndex="1" GridPane.rowIndex="1"
                           styleClass="value-bg"/>

                    <Label text="Rôle" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           styleClass="label-bold"/>
                    <Label fx:id="roleDisplay" GridPane.columnIndex="1" GridPane.rowIndex="2"
                           styleClass="role-badge"/>

                    <Label text="Statut" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           styleClass="label-bold"/>
                    <Label fx:id="statusDisplay" GridPane.columnIndex="1" GridPane.rowIndex="3"
                           styleClass="status-badge"/>
                </GridPane>
            </VBox>

            <VBox spacing="14"
                  styleClass="card"
                  style="-fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 28;">
                <Label text="⚡  Actions rapides"
                       styleClass="card-title"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Semibold';"/>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Button fx:id="settingsButton" text="⚙️  Paramètres"
                            styleClass="button-warning"
                            style="-fx-font-size: 13; -fx-padding: 11 26; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 6, 0, 0, 2);"/>
                    <Button fx:id="userListButton" text="👥  Gestion des utilisateurs"
                            visible="false" managed="false"
                            styleClass="button-primary"
                            style="-fx-font-size: 13; -fx-padding: 11 26; -fx-effect: dropshadow(gaussian, rgba(11,99,206,0.3), 6, 0, 0, 2);"/>
                </HBox>
            </VBox>

            <HBox styleClass="status-bar" style="-fx-padding: 12 22; -fx-background-radius: 40;">
                <Label text="🔌  Connecté – INTEGRA RH Management"
                       styleClass="status-text" style="-fx-font-size: 12; -fx-font-family: 'Segoe UI'; -fx-font-weight: 500;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>