<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="theme-light" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.UserListController">
    <top>
        <HBox styleClass="top-bar" spacing="10">
            <Label text="INTEGRA" styleClass="logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userNameLabel" styleClass="user-info"/>
            <Button fx:id="logoutButton" text="Déconnexion" styleClass="logout-button"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar">
            <Button fx:id="navDashboard" text="🏠 Dashboard"/>
            <Button fx:id="navUsers" text="👥 Utilisateurs"/>
            <Button fx:id="navFormations" text="📚 Formations"/>
            <Button fx:id="navProjets" text="📁 Projets"/>
            <Button fx:id="navRecrutement" text="📋 Recrutement"/>
            <Button fx:id="navSalaire" text="💰 Salaire"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Gestion des utilisateurs" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <ListView fx:id="userListView" VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="addButton" text="Ajouter"/>
                <Button fx:id="editButton" text="Modifier"/>
                <Button fx:id="deleteButton" text="Supprimer"/>
                <Button fx:id="settingsButton" text="Paramètres"/>
                <Button fx:id="refreshButton" text="Actualiser"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>