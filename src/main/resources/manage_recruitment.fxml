<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.manageRecruitment"
            prefWidth="1400" prefHeight="900"
            style="-fx-background-color: #f0f4f8;">

    <!-- ═══════════ HEADER ═══════════ -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B);
                         -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.2),10,0,0,2);">
                <padding><Insets top="14" right="25" bottom="14" left="25"/></padding>

                <ImageView fitHeight="44" fitWidth="44" preserveRatio="true">
                    <image><Image url="@images/logo.png"/></image>
                </ImageView>

                <VBox spacing="1">
                    <Label text="INTEGRA RECRUITMENT" textFill="WHITE"
                           style="-fx-font-size: 21; -fx-font-weight: bold;"/>
                    <Label text="Gestion des recrutements" textFill="WHITE"
                           style="-fx-font-size: 12; -fx-opacity: 0.88;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Admin User" textFill="WHITE"
                               style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                        <Label text="Administrateur" textFill="WHITE"
                               style="-fx-font-size: 11; -fx-opacity: 0.85;"/>
                    </VBox>
                    <Button text="📊 Statistiques" onAction="#onOpenStatistiques"
                            style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-border-color: rgba(255,255,255,0.5); -fx-border-radius: 10;
                                   -fx-border-width: 1; -fx-padding: 8 16;"
                            prefHeight="36"/>
                    <Button text="Déconnexion" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-border-color: rgba(255,255,255,0.4); -fx-border-radius: 10;
                                   -fx-border-width: 1; -fx-padding: 8 16;"
                            prefHeight="36"/>
                </HBox>
            </HBox>

            <!-- Stats bar -->
            <HBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                <padding><Insets top="10" right="25" bottom="10" left="25"/></padding>

                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <StackPane minWidth="36" minHeight="36"
                               style="-fx-background-color: #eff6ff; -fx-background-radius: 8;">
                        <Label text="📊" style="-fx-font-size: 16;"/>
                    </StackPane>
                    <VBox spacing="0">
                        <Label text="Total Jobs" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;"/>
                        <Label fx:id="statsTotalJobs" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-size: 19;"/>
                    </VBox>
                </HBox>

                <Separator orientation="VERTICAL" prefHeight="36" style="-fx-opacity: 0.3;"/>

                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <padding><Insets left="20"/></padding>
                    <StackPane minWidth="36" minHeight="36"
                               style="-fx-background-color: #f0fdf4; -fx-background-radius: 8;">
                        <Label text="👥" style="-fx-font-size: 16;"/>
                    </StackPane>
                    <VBox spacing="0">
                        <Label text="Total Candidats" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;"/>
                        <Label fx:id="statsTotalCandidats" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #0FA36B; -fx-font-size: 19;"/>
                    </VBox>
                </HBox>

                <Separator orientation="VERTICAL" prefHeight="36" style="-fx-opacity: 0.3;"/>

                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <padding><Insets left="20"/></padding>
                    <StackPane minWidth="36" minHeight="36"
                               style="-fx-background-color: #f0fdf4; -fx-background-radius: 8;">
                        <Label text="✅" style="-fx-font-size: 16;"/>
                    </StackPane>
                    <VBox spacing="0">
                        <Label text="Jobs ouverts" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;"/>
                        <Label fx:id="statsOpenJobs" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #22c55e; -fx-font-size: 19;"/>
                    </VBox>
                </HBox>

                <Separator orientation="VERTICAL" prefHeight="36" style="-fx-opacity: 0.3;"/>

                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <padding><Insets left="20"/></padding>
                    <StackPane minWidth="36" minHeight="36"
                               style="-fx-background-color: #fffbeb; -fx-background-radius: 8;">
                        <Label text="⏳" style="-fx-font-size: 16;"/>
                    </StackPane>
                    <VBox spacing="0">
                        <Label text="En cours" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;"/>
                        <Label fx:id="statsInReview" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #f59e0b; -fx-font-size: 19;"/>
                    </VBox>
                </HBox>

                <!-- Label caché pour compat controller -->
                <Label fx:id="statsTotalJobs2" visible="false" managed="false"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════ CONTENU ═══════════ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #f0f4f8; -fx-border-color: transparent;">
            <VBox spacing="20">
                <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

                <!-- ──────── SECTION OFFRES D'EMPLOI ──────── -->
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 16;
                             -fx-border-color: #e2e8f0; -fx-border-radius: 16; -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.05),8,0,0,2);">
                    <padding><Insets top="16" right="18" bottom="18" left="18"/></padding>

                    <!-- Titre section + boutons -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="💼" style="-fx-font-size: 18;"/>
                        <Label text="OFFRES D'EMPLOI"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #0B63CE;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="＋ Nouvelle offre" onAction="#onAddJob"
                                style="-fx-background-color: #0B63CE; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 7 16;"
                                prefHeight="34"/>
                        <Button text="✏ Modifier" onAction="#onEditJob"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 7 16;"
                                prefHeight="34"/>
                        <Button text="🗑 Supprimer" onAction="#onDeleteJob"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 7 16;"
                                prefHeight="34"/>
                    </HBox>

                    <Separator style="-fx-opacity: 0.25;"/>

                    <!--
                        ✅ VBox VERTICAL : les cartes s'empilent vers le bas.
                           Pas de scroll horizontal. Tout est lisible immédiatement.
                           Les cartes s'ajoutent dynamiquement depuis manageRecruitment.java.
                    -->
                    <VBox fx:id="jobCardsContainer" spacing="8"/>
                </VBox>

                <!-- ──────── SECTION CANDIDATS ──────── -->
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 16;
                             -fx-border-color: #e2e8f0; -fx-border-radius: 16; -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.05),8,0,0,2);">
                    <padding><Insets top="16" right="18" bottom="18" left="18"/></padding>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="👥" style="-fx-font-size: 18;"/>
                        <VBox spacing="1">
                            <Label text="CANDIDATS"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #0FA36B;"/>
                            <Label fx:id="lblForJob"
                                   text="Sélectionnez une offre pour voir ses candidats"
                                   style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="tfSearchCand"
                                   promptText="🔍 Rechercher un candidat..."
                                   prefWidth="220"
                                   style="-fx-background-radius: 10; -fx-border-radius: 10;
                                          -fx-border-color: #e2e8f0; -fx-padding: 7 12; -fx-font-size: 12;"/>
                        <Button text="✖" onAction="#onClearSearch"
                                style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b;
                                       -fx-font-weight: bold; -fx-background-radius: 8;
                                       -fx-cursor: hand; -fx-padding: 7 10;" prefHeight="32"/>
                        <Button text="＋ Ajouter" onAction="#onAddCandidat"
                                style="-fx-background-color: #0FA36B; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 7 14;"
                                prefHeight="34"/>
                        <Button text="✏ Modifier" onAction="#onEditCandidat"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 7 14;"
                                prefHeight="34"/>
                        <Button text="🗑 Supprimer" onAction="#onDeleteCandidat"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 7 14;"
                                prefHeight="34"/>
                    </HBox>

                    <Separator style="-fx-opacity: 0.25;"/>

                    <TableView fx:id="candidatTable" prefHeight="260"
                               style="-fx-background-radius: 10; -fx-border-radius: 10;
                                      -fx-border-color: #e2e8f0; -fx-border-width: 1;">
                        <columns>
                            <TableColumn fx:id="colCandId"        text="ID"          prefWidth="55"/>
                            <TableColumn fx:id="colCandFullName"  text="Nom complet" prefWidth="190"/>
                            <TableColumn fx:id="colCandEmail"     text="Email"       prefWidth="230"/>
                            <TableColumn fx:id="colCandEducation" text="Niveau"      prefWidth="140"/>
                            <TableColumn fx:id="colCandStatus"    text="Statut"      prefWidth="110"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- ──────── SECTION DÉTAILS CANDIDAT ──────── -->
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 16;
                             -fx-border-color: #e2e8f0; -fx-border-radius: 16; -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.05),8,0,0,2);">
                    <padding><Insets top="16" right="18" bottom="18" left="18"/></padding>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="📋" style="-fx-font-size: 17;"/>
                        <Label text="DÉTAILS DU CANDIDAT"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #0B63CE;"/>
                    </HBox>

                    <Separator style="-fx-opacity: 0.25;"/>

                    <GridPane hgap="18" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="12"/>
                            <ColumnConstraints percentWidth="36"/>
                            <ColumnConstraints percentWidth="12"/>
                            <ColumnConstraints percentWidth="40"/>
                        </columnConstraints>

                        <Label text="Nom complet :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-size: 12;"
                               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="dFullName" text="—"
                               style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 13;"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="Email :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0FA36B; -fx-font-size: 12;"
                               GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <Label fx:id="dEmail" text="—"
                               style="-fx-text-fill: #0B63CE; -fx-font-size: 12;"
                               GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Téléphone :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-size: 12;"
                               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="dPhone" text="—"
                               style="-fx-text-fill: #1e293b; -fx-font-size: 12;"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Niveau d'étude :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0FA36B; -fx-font-size: 12;"
                               GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <Label fx:id="dEducation" text="—"
                               style="-fx-text-fill: #1e293b; -fx-font-size: 12;"
                               GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Compétences :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-size: 12;"
                               GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextArea fx:id="dSkills" editable="false" wrapText="true" prefRowCount="3"
                                  style="-fx-background-radius: 10; -fx-border-radius: 10;
                                         -fx-border-color: #e2e8f0; -fx-font-size: 12;
                                         -fx-background-color: #f8fafc;"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                        <!-- Boutons actions -->
                        <HBox spacing="10" alignment="CENTER"
                              GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="4">
                            <padding><Insets top="8"/></padding>
                            <Button text="🔄 Mettre à jour statut" onAction="#onUpdateStatus"
                                    style="-fx-background-color: #8b5cf6; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-cursor: hand; -fx-font-size: 12; -fx-padding: 8 14;"
                                    prefHeight="36"/>
                            <Button text="📧 Envoyer Email" onAction="#onSendEmail"
                                    style="-fx-background-color: #0B63CE; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-cursor: hand; -fx-font-size: 12; -fx-padding: 8 14;"
                                    prefHeight="36"/>
                            <Button text="📋 Voir CV" onAction="#onViewCv"
                                    style="-fx-background-color: #0B63CE; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-cursor: hand; -fx-font-size: 12; -fx-padding: 8 14;"
                                    prefHeight="36"/>
                            <Button text="📄 Exporter PDF" onAction="#onExportAllCandidatsPDF"
                                    style="-fx-background-color: #8b5cf6; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-cursor: hand; -fx-font-size: 12; -fx-padding: 8 14;"
                                    prefHeight="36"/>
                            <Button text="❌ Rejeter" onAction="#onReject"
                                    style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-cursor: hand; -fx-font-size: 12; -fx-padding: 8 14;"
                                    prefHeight="36"/>
                        </HBox>
                    </GridPane>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
