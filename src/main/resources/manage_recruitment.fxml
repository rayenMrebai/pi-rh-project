<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.manageRecruitment"
            prefWidth="1400" prefHeight="850"
            style="-fx-background-color: #f0f2f5;">

    <!-- HEADER AVEC DÉGRADÉ BLEU/VERT -->
    <top>
        <VBox>
            <!-- Top Bar avec dégradé -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 2);">
                <padding>
                    <Insets top="15" right="25" bottom="15" left="25"/>
                </padding>

                <ImageView fitHeight="50" fitWidth="50" preserveRatio="true">
                    <image>
                        <Image url="@images/logo.png"/>
                    </image>
                </ImageView>

                <VBox>
                    <Label text="INTEGRA RECRUITMENT"
                           textFill="WHITE"
                           style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                    <Label text="Gestion des recrutements"
                           textFill="WHITE"
                           style="-fx-font-size: 13; -fx-opacity: 0.9;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Admin User"
                               textFill="WHITE"
                               style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                        <Label text="Administrateur"
                               textFill="WHITE"
                               style="-fx-font-size: 11; -fx-opacity: 0.9;"/>
                    </VBox>

                    <Button text="Déconnexion" onAction="#onLogout"
                            style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 20; -fx-border-width: 1;"
                            prefHeight="40" prefWidth="120">
                        <padding>
                            <Insets left="15" right="15"/>
                        </padding>
                    </Button>
                    <!-- Dans le header, après le bouton Logout -->
                    <Button text="📊 Statistiques" onAction="#onOpenStatistiques"
                            style="-fx-background-color: #0FA36B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 20; -fx-border-width: 1;"
                            prefHeight="40" prefWidth="120">
                        <padding>
                            <Insets left="15" right="15"/>
                        </padding>
                    </Button>
                </HBox>
            </HBox>

            <!-- Quick Stats Bar -->
            <HBox spacing="30" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets top="15" right="25" bottom="15" left="25"/>
                </padding>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="📊" style="-fx-font-size: 20;"/>
                    <VBox>
                        <Label text="Total Jobs" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
                        <Label fx:id="statsTotalJobs" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-size: 18;"/>
                    </VBox>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="👥" style="-fx-font-size: 20;"/>
                    <VBox>
                        <Label text="Total Candidats" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
                        <Label fx:id="statsTotalCandidats" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #0FA36B; -fx-font-size: 18;"/>
                    </VBox>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="✅" style="-fx-font-size: 20;"/>
                    <VBox>
                        <Label text="Jobs ouverts" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
                        <Label fx:id="statsOpenJobs" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #22c55e; -fx-font-size: 18;"/>
                    </VBox>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="⏳" style="-fx-font-size: 20;"/>
                    <VBox>
                        <Label text="En cours" style="-fx-text-fill: #64748b; -fx-font-size: 11;"/>
                        <Label fx:id="statsInReview" text="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #f59e0b; -fx-font-size: 18;"/>
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- CONTENT PRINCIPAL -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="25">
                <padding>
                    <Insets top="20" right="25" bottom="20" left="25"/>
                </padding>

                <!-- SECTION: JOB POSITIONS AVEC TITRE BLEU -->
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="💼" style="-fx-font-size: 28;"/>
                        <Label text="OFFRES D'EMPLOI"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0B63CE;"/>
                        <Label text="(" fx:id="statsTotalJobs2" style="-fx-font-size: 16; -fx-text-fill: #64748b;"/>
                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="+ Nouvelle offre" onAction="#onAddJob"
                                style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                prefHeight="40" prefWidth="150">
                            <padding>
                                <Insets left="20" right="20"/>
                            </padding>
                        </Button>

                        <Button text="Modifier" onAction="#onEditJob"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                prefHeight="40" prefWidth="100">
                            <padding>
                                <Insets left="20" right="20"/>
                            </padding>
                        </Button>

                        <Button text="Supprimer" onAction="#onDeleteJob"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                prefHeight="40" prefWidth="100">
                            <padding>
                                <Insets left="20" right="20"/>
                            </padding>
                        </Button>
                    </HBox>

                    <!-- Job Cards Container avec scroll horizontal -->
                    <ScrollPane fitToHeight="true" fitToWidth="false"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;"
                                prefHeight="350">
                        <HBox fx:id="jobCardsContainer" spacing="20"
                              style="-fx-background-color: transparent;">
                            <!-- Les cartes seront ajoutées dynamiquement -->
                        </HBox>
                    </ScrollPane>
                </VBox>

                <!-- SECTION: CANDIDATS AVEC TITRE VERT -->
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="👥" style="-fx-font-size: 28;"/>
                        <VBox>
                            <Label text="CANDIDATS"
                                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0FA36B;"/>
                            <Label fx:id="lblForJob"
                                   text="Sélectionnez une offre pour voir ses candidats"
                                   style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Filtres et recherche -->
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <TextField fx:id="tfSearchCand"
                                       promptText="Rechercher un candidat..."
                                       prefWidth="250"
                                       style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #e2e8f0; -fx-padding: 10 15; -fx-font-size: 13;"/>

                            <Button text="Clear" onAction="#onClearSearch"
                                    style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="80">
                                <padding>
                                    <Insets left="15" right="15"/>
                                </padding>
                            </Button>

                            <Button text="+ Ajouter" onAction="#onAddCandidat"
                                    style="-fx-background-color: #0FA36B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="100">
                                <padding>
                                    <Insets left="15" right="15"/>
                                </padding>
                            </Button>

                            <Button text="Modifier" onAction="#onEditCandidat"
                                    style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="90">
                                <padding>
                                    <Insets left="15" right="15"/>
                                </padding>
                            </Button>

                            <Button text="Supprimer" onAction="#onDeleteCandidat"
                                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="90">
                                <padding>
                                    <Insets left="15" right="15"/>
                                </padding>
                            </Button>
                        </HBox>
                    </HBox>

                    <!-- Tableau des candidats avec bordures arrondies -->
                    <TableView fx:id="candidatTable" VBox.vgrow="ALWAYS" prefHeight="300"
                               style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #e2e8f0; -fx-border-width: 1;">
                        <columns>
                            <TableColumn fx:id="colCandId" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colCandFullName" text="Nom complet" prefWidth="200"/>
                            <TableColumn fx:id="colCandEmail" text="Email" prefWidth="250"/>
                            <TableColumn fx:id="colCandEducation" text="Niveau" prefWidth="150"/>
                            <TableColumn fx:id="colCandStatus" text="Statut" prefWidth="120"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- SECTION: DÉTAILS DU CANDIDAT -->
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📋" style="-fx-font-size: 24;"/>
                        <Label text="DÉTAILS DU CANDIDAT"
                               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0B63CE;"/>
                    </HBox>

                    <GridPane hgap="20" vgap="15"
                              style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-border-width: 1;">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="15"/>
                            <ColumnConstraints percentWidth="35"/>
                            <ColumnConstraints percentWidth="15"/>
                            <ColumnConstraints percentWidth="35"/>
                        </columnConstraints>

                        <!-- Ligne 1 -->
                        <Label text="Nom complet :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE;"
                               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="dFullName" text="-"
                               style="-fx-text-fill: #1e293b; -fx-font-weight: bold;"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Email :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0FA36B;"
                               GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <Label fx:id="dEmail" text="-"
                               style="-fx-text-fill: #1e293b;"
                               GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <!-- Ligne 2 -->
                        <Label text="Téléphone :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE;"
                               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="dPhone" text="-"
                               style="-fx-text-fill: #1e293b;"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Niveau d'étude :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0FA36B;"
                               GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <Label fx:id="dEducation" text="-"
                               style="-fx-text-fill: #1e293b;"
                               GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <!-- Ligne 3 - Compétences -->
                        <Label text="Compétences :"
                               style="-fx-font-weight: bold; -fx-text-fill: #0B63CE;"
                               GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextArea fx:id="dSkills" editable="false" wrapText="true" prefRowCount="3"
                                  style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-font-size: 13;"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                        <!-- Ligne 4 - Actions -->
                        <HBox spacing="15" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="4" alignment="CENTER">
                            <padding>
                                <Insets top="15"/>
                            </padding>

                            <Button text="Mettre à jour le statut" onAction="#onUpdateStatus"
                                    style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="200">
                                <padding>
                                    <Insets left="20" right="20"/>
                                </padding>
                            </Button>
                            <Button text="📧 Envoyer Email" onAction="#onSendEmail"
                                    style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="150"/>
                            <Button text="Voir CV" onAction="#onViewCv"
                                    style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="120">
                                <padding>
                                    <Insets left="20" right="20"/>
                                </padding>
                            </Button>

                            <Button text="Rejeter" onAction="#onReject"
                                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13;"
                                    prefHeight="40" prefWidth="120">
                                <padding>
                                    <Insets left="20" right="20"/>
                                </padding>
                            </Button>
                        </HBox>
                    </GridPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>