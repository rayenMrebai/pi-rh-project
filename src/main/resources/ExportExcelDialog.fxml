<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.ExportExcelDialogController"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #f7fafc;">

    <VBox spacing="15"
          AnchorPane.topAnchor="15"
          AnchorPane.leftAnchor="15"
          AnchorPane.rightAnchor="15"
          AnchorPane.bottomAnchor="15">

        <!-- HEADER -->
        <HBox alignment="CENTER"
              style="-fx-background-color: linear-gradient(to right, #667eea 0%, #764ba2 100%);
                     -fx-background-radius: 10; -fx-padding: 20;">
            <VBox alignment="CENTER">
                <Label text="📊 EXPORT EXCEL"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Configuration de l'export"
                       style="-fx-font-size: 12px; -fx-text-fill: white;"/>
            </VBox>
        </HBox>

        <!-- CORPS HORIZONTAL -->
        <HBox spacing="20">

            <!-- COLONNE GAUCHE -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">

                <!-- SECTION 1 -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label text="1️⃣ PÉRIODE D'EXPORT"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                    <Separator/>

                    <RadioButton fx:id="rbTous" text="Tous les salaires" selected="true">
                        <toggleGroup>
                            <ToggleGroup fx:id="periodeGroup"/>
                        </toggleGroup>
                    </RadioButton>

                    <HBox spacing="10">
                        <RadioButton fx:id="rbMois" text="Par mois :" toggleGroup="$periodeGroup"/>
                        <ComboBox fx:id="cmbMois" prefWidth="110" disable="true"/>
                        <ComboBox fx:id="cmbAnneeMois" prefWidth="90" disable="true"/>
                    </HBox>

                    <HBox spacing="10">
                        <RadioButton fx:id="rbAnnee" text="Par année :" toggleGroup="$periodeGroup"/>
                        <ComboBox fx:id="cmbAnnee" prefWidth="120" disable="true"/>
                    </HBox>

                    <VBox spacing="5">
                        <RadioButton fx:id="rbPersonnalisee"
                                     text="Période personnalisée :" toggleGroup="$periodeGroup"/>
                        <HBox spacing="10" style="-fx-padding: 0 0 0 25;">
                            <DatePicker fx:id="dpDebut" prefWidth="130" disable="true"/>
                            <DatePicker fx:id="dpFin" prefWidth="130" disable="true"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- SECTION 4 -->
                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label text="📁 Nom du fichier"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtFilename" promptText="salaires_export.xlsx"/>
                </VBox>

            </VBox>

            <!-- COLONNE DROITE -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">

                <!-- SECTION 2 -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label text="2️⃣ FILTRES OPTIONNELS"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Separator/>

                    <HBox spacing="15">
                        <CheckBox fx:id="chkPaye" text="PAYÉ" selected="true"/>
                        <CheckBox fx:id="chkEnCours" text="EN_COURS" selected="true"/>
                        <CheckBox fx:id="chkCree" text="CRÉÉ" selected="true"/>
                    </HBox>

                    <HBox spacing="10">
                        <CheckBox fx:id="chkFilterMontant" text="Montant minimum :"/>
                        <TextField fx:id="txtMontantMin" prefWidth="120" disable="true"/>
                        <Label text="DT"/>
                    </HBox>
                </VBox>

                <!-- SECTION 3 -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label text="3️⃣ OPTIONS D'EXPORT"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Separator/>

                    <CheckBox fx:id="chkStatistiques" text="Inclure feuille Statistiques" selected="true"/>
                    <CheckBox fx:id="chkBonus" text="Inclure détails règles de bonus"/>
                    <CheckBox fx:id="chkFormatage" text="Appliquer formatage couleurs" selected="true"/>
                </VBox>

            </VBox>
        </HBox>

        <!-- BOUTONS -->
        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="btnAnnuler" text="Annuler" prefWidth="120" prefHeight="40"
                    onAction="#handleAnnuler"/>
            <Button fx:id="btnExporter" text="📊 Exporter" prefWidth="150" prefHeight="40"
                    onAction="#handleExporter"/>
        </HBox>

    </VBox>
</AnchorPane>