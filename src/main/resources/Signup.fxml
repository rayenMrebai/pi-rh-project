<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.SignUpController"
            style="-fx-background-color: #f8fafc;">
    <center>
        <VBox alignment="CENTER" spacing="20" maxWidth="480"
              style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 30, 0, 0, 8); -fx-padding: 40 44;">

            <VBox alignment="CENTER" spacing="6">
                <Label text="INTEGRA"
                       style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-family: 'Segoe UI Semibold';"/>
                <Label text="Créer un nouveau compte"
                       style="-fx-font-size: 13; -fx-text-fill: #6b7280; -fx-font-family: 'Segoe UI';"/>
            </VBox>

            <GridPane hgap="10" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="130" maxWidth="130"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Nom d'utilisateur" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                           promptText="Nom d'utilisateur"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dbeafe; -fx-background-color: #f8fafc; -fx-padding: 9 14; -fx-font-size: 13;"/>

                <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                           promptText="adresse@email.com"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dbeafe; -fx-background-color: #f8fafc; -fx-padding: 9 14; -fx-font-size: 13;"/>

                <Label text="Mot de passe" GridPane.columnIndex="0" GridPane.rowIndex="2"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               promptText="Mot de passe"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dbeafe; -fx-background-color: #f8fafc; -fx-padding: 9 14; -fx-font-size: 13;"/>

                <Label text="Confirmer" GridPane.columnIndex="0" GridPane.rowIndex="3"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                               promptText="Confirmer le mot de passe"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dbeafe; -fx-background-color: #f8fafc; -fx-padding: 9 14; -fx-font-size: 13;"/>

                <Label text="Rôle" GridPane.columnIndex="0" GridPane.rowIndex="4"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="roleCombo" GridPane.columnIndex="1" GridPane.rowIndex="4"
                          maxWidth="Infinity"
                          style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dbeafe; -fx-background-color: #f8fafc; -fx-padding: 4 10; -fx-font-size: 13;"/>

                <Button fx:id="signUpButton" text="S'inscrire" GridPane.columnIndex="1" GridPane.rowIndex="5"
                        maxWidth="Infinity"
                        style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(11,99,206,0.3), 10, 0, 0, 4);"/>

                <Hyperlink fx:id="loginLink" text="Déjà un compte ? Se connecter"
                           GridPane.columnIndex="1" GridPane.rowIndex="6"
                           style="-fx-text-fill: #0B63CE; -fx-font-size: 12; -fx-border-color: transparent;"/>
            </GridPane>
        </VBox>
    </center>
</BorderPane>
