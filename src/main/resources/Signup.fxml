<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane styleClass="theme-light" stylesheets="@style.css" alignment="CENTER" hgap="10" vgap="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SignUpController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <Label text="Nom d'utilisateur" GridPane.columnIndex="0" GridPane.rowIndex="0" />
    <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

    <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="1" />
    <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

    <Label text="Mot de passe" GridPane.columnIndex="0" GridPane.rowIndex="2" />
    <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

    <Label text="Confirmer" GridPane.columnIndex="0" GridPane.rowIndex="3" />
    <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

    <Label text="Rôle" GridPane.columnIndex="0" GridPane.rowIndex="4" />
    <ComboBox fx:id="roleCombo" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="200.0" />

    <Button fx:id="signUpButton" text="S'inscrire" GridPane.columnIndex="1" GridPane.rowIndex="5" />

    <Hyperlink fx:id="loginLink" text="Déjà un compte ? Se connecter" GridPane.columnIndex="1" GridPane.rowIndex="6" />
</GridPane>