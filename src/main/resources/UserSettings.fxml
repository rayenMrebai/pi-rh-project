<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.UserSettingsController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;">
    <content>
        <VBox spacing="20" style="-fx-background-color: #f8fafc;">
            <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-padding: 20 25;">
                <VBox spacing="4">
                    <Label text="⚙️  Paramètres utilisateur"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';"/>
                    <Label text="Personnalisez votre expérience INTEGRA"
                           style="-fx-font-size: 12; -fx-text-fill: #b0c4de; -fx-font-family: 'Segoe UI';"/>
                </VBox>
            </HBox>

            <!-- SETTINGS CARD (thème et langue) -->
            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 25;">
                <Label text="🎨  Préférences d'affichage"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI Semibold';"/>

                <GridPane hgap="20" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints minWidth="160" maxWidth="160"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Thème" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="themeCombo" GridPane.columnIndex="1" GridPane.rowIndex="0"
                              maxWidth="Infinity"
                              style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dbeafe; -fx-background-color: #f8fafc; -fx-padding: 4 10; -fx-font-size: 13;"/>

                    <Label text="Langue" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="languageCombo" GridPane.columnIndex="1" GridPane.rowIndex="1"
                              maxWidth="Infinity"
                              style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dbeafe; -fx-background-color: #f8fafc; -fx-padding: 4 10; -fx-font-size: 13;"/>
                </GridPane>
            </VBox>

            <!-- FACE ENROLLMENT CARD -->
            <VBox spacing="12"
                  style="-fx-background-color: #f0f9ff; -fx-background-radius: 20; -fx-border-color: #dbeafe; -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 20;">
                <Label text="📷  Reconnaissance faciale"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0B63CE; -fx-font-family: 'Segoe UI Semibold';"/>
                <Label text="Enrôlez votre visage pour pouvoir vous connecter via la reconnaissance faciale."
                       style="-fx-font-size: 13; -fx-text-fill: #6b7280;" wrapText="true"/>
                <Button fx:id="enrollFaceButton" text="📷  Enrôler mon visage" maxWidth="Infinity"
                        style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 30; -fx-padding: 12 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(11,99,206,0.3), 10, 0, 0, 4);"/>
            </VBox>

            <!-- ACTION BUTTONS -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button fx:id="cancelButton" text="Annuler"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 28; -fx-cursor: hand;"/>
                <Button fx:id="saveButton" text="✅  Enregistrer"
                        style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-background-radius: 30; -fx-padding: 10 28; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(11,99,206,0.3), 8, 0, 0, 3);"/>
            </HBox>

            <!-- STATUS BAR -->
            <HBox style="-fx-background-color: linear-gradient(to right, #e2eaf8, #d4e0f0); -fx-padding: 12 20; -fx-background-radius: 40;">
                <Label text="⚙️  INTEGRA – Paramètres utilisateur"
                       style="-fx-text-fill: #1e3a5f; -fx-font-size: 12; -fx-font-family: 'Segoe UI'; -fx-font-weight: 500;"/>
            </HBox>
        </VBox>
    </content>
</ScrollPane>