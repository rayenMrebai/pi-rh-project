<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.UserTrainingDetailController"
      prefWidth="640" spacing="0"
      style="-fx-background-color: #f0f2f5;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: linear-gradient(to right, #1565c0, #1976d2);
                 -fx-padding: 16 20;">
        <Label text="📚" style="-fx-font-size: 22px;"/>
        <VBox spacing="2">
            <Label fx:id="titleLabel" text="Formation"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label text="Détails de la formation"
                   style="-fx-text-fill: #90caf9; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <VBox spacing="14" style="-fx-background-color: white; -fx-padding: 24;">

        <!-- Ligne 1 : Type / Statut / Durée -->
        <HBox spacing="20">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="TYPE" style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                <Label fx:id="typeLabel" text="—"
                       style="-fx-font-size: 12px; -fx-font-weight: bold;
                              -fx-background-color: #1976d2; -fx-text-fill: white;
                              -fx-padding: 3 8; -fx-background-radius: 4;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="STATUT" style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                <Label fx:id="statusLabel" text="—"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="DURÉE" style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                <Label fx:id="durationLabel" text="—"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #37474f;"/>
            </VBox>
        </HBox>

        <!-- Ligne 2 : Dates / Compétence -->
        <HBox spacing="20">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="DATE DÉBUT"
                       style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                <Label fx:id="startDateLabel" text="—"
                       style="-fx-font-size: 12px; -fx-text-fill: #546e7a;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="DATE FIN"
                       style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                <Label fx:id="endDateLabel" text="—"
                       style="-fx-font-size: 12px; -fx-text-fill: #546e7a;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="COMPÉTENCE CIBLÉE"
                       style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                <Label fx:id="skillLabel" text="—"
                       style="-fx-font-size: 12px; -fx-text-fill: #546e7a;"/>
            </VBox>
        </HBox>

        <!-- Description -->
        <VBox spacing="4">
            <Label text="DESCRIPTION"
                   style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
            <Label fx:id="descriptionLabel" text="—" wrapText="true"
                   style="-fx-font-size: 13px; -fx-text-fill: #37474f;"/>
        </VBox>

        <Separator/>

        <!-- SECTION QUIZ -->
        <VBox fx:id="quizPanel" spacing="10"
              style="-fx-background-color: #e3f2fd; -fx-background-radius: 8;
                     -fx-padding: 16; -fx-border-color: #90caf9;
                     -fx-border-radius: 8; -fx-border-width: 1;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="📝" style="-fx-font-size: 18px;"/>
                <Label text="Quiz de la Formation"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;
                              -fx-text-fill: #0d47a1;"/>
            </HBox>
            <Label fx:id="quizStatusLabel" text="📝 Quiz disponible"
                   style="-fx-font-size: 12px; -fx-text-fill: #1976d2;
                          -fx-font-weight: bold;"/>
            <Label text="10 questions • Choix multiples • 1 seule tentative autorisée"
                   style="-fx-font-size: 11px; -fx-text-fill: #546e7a;"/>
            <Button fx:id="startQuizBtn"
                    text="🚀  Démarrer le Quiz"
                    onAction="#handleStartQuiz"
                    style="-fx-background-color: #1565c0; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10 24;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-font-size: 13px;"/>
        </VBox>

        <!-- SECTION RÉSULTAT — caché par défaut -->
        <VBox fx:id="resultPanel" spacing="10"
              visible="false" managed="false"
              style="-fx-background-color: #f1f8e9; -fx-background-radius: 8;
                     -fx-padding: 16; -fx-border-color: #a5d6a7;
                     -fx-border-radius: 8; -fx-border-width: 1;">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="🏆" style="-fx-font-size: 18px;"/>
                <Label text="Votre Résultat"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;
                              -fx-text-fill: #1b5e20;"/>
            </HBox>
            <HBox spacing="30" alignment="CENTER_LEFT">
                <VBox spacing="2">
                    <Label text="Score"
                           style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                    <Label fx:id="resultScoreLabel" text="—"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #1b5e20;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Pourcentage"
                           style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                    <Label fx:id="resultPercentLabel" text="—"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #1976d2;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Résultat"
                           style="-fx-font-size: 10px; -fx-text-fill: #90a4ae;"/>
                    <Label fx:id="resultPassedLabel" text="—"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
            <Label fx:id="resultDateLabel" text="—"
                   style="-fx-font-size: 11px; -fx-text-fill: #90a4ae;
                          -fx-font-style: italic;"/>
        </VBox>

        <!-- Bouton fermer -->
        <HBox alignment="CENTER_RIGHT">
            <Button text="✕  Fermer" onAction="#handleClose"
                    style="-fx-background-color: #eceff1; -fx-text-fill: #546e7a;
                           -fx-font-weight: bold; -fx-padding: 10 24;
                           -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</VBox>