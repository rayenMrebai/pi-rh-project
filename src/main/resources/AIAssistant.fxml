<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.AIAssistantController"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;">
    <content>
        <VBox spacing="25" style="-fx-background-color: #f8fafc;">
            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: linear-gradient(to right, #0B63CE, #0FA36B); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-padding: 20 25;">
                <Label text="🧠 IA Project Assistant"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold';"/>
            </HBox>

            <!-- Project info (small) -->
            <Label fx:id="projectNameLabel" style="-fx-font-size: 14; -fx-text-fill: #1e3a5f; -fx-font-weight: bold;"/>

            <!-- Section Résumé -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📄 Résumé du projet" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0B63CE;"/>
                    <Button fx:id="generateSummaryButton" text="Générer Résumé"
                            style="-fx-background-color: #0B63CE; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                <TextArea fx:id="summaryArea" wrapText="true" prefRowCount="4"
                          promptText="Le résumé apparaîtra ici..." style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d1d5db; -fx-padding: 8;"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="copySummaryButton" text="Copier"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 6 16; -fx-cursor: hand;"/>
                    <Button fx:id="translateButton" text="Traduire EN"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 6 16; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Section Amélioration de la description -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="✨ Amélioration de la description" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0FA36B;"/>
                    <Button fx:id="improveButton" text="🤖 Améliorer"
                            style="-fx-background-color: #0FA36B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                <TextArea fx:id="improvedDescriptionArea" wrapText="true" prefRowCount="4"
                          promptText="Description améliorée..." style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d1d5db; -fx-padding: 8;"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="replaceDescriptionButton" text="Remplacer Description"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 20; -fx-cursor: hand;"/>
                    <Button fx:id="closeButton" text="Fermer"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 20; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>