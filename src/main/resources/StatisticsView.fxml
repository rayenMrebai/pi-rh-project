<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.StatisticsController"
            prefHeight="900.0" prefWidth="1400.0"
            style="-fx-background-color: #f7fafc;">

    <VBox spacing="0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- ⭐ NAVBAR (IDENTIQUE) -->
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #667eea 0%, #764ba2 100%); -fx-padding: 0;">

            <Button fx:id="btnNavSalaires" text="📋 Gestion des Salaires"
                    prefHeight="60" prefWidth="250"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 0;"
                    onAction="#handleNavSalaires"/>

            <Button fx:id="btnNavStatistics" text="📊 Statistiques et IA"
                    prefHeight="60" prefWidth="250"
                    style="-fx-background-color: rgba(255,255,255,0.3); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 0; -fx-border-width: 0 0 4 0; -fx-border-color: white;"
                    onAction="#handleNavStatistics"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="INTEGRA - Système RH"
                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 0 20 0 0;"/>
        </HBox>

        <!-- CONTENU STATISTIQUES -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 20;">

                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="20"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="📊 Statistiques et IA"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Analyse intelligente des données de salaires"
                               style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                    </VBox>

                    <ProgressIndicator fx:id="progressIndicator" prefWidth="30" prefHeight="30" visible="false"/>

                    <Button fx:id="btnRefresh" text="🔄 Actualiser"
                            prefHeight="40" prefWidth="140"
                            style="-fx-background-color: #4299e1; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8;"
                            onAction="#handleRefresh"/>
                </HBox>

                <!-- STATISTIQUES CLÉS -->
                <GridPane hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <VBox GridPane.columnIndex="0" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="📊 Nombre total" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                        <Label fx:id="lblTotalCount" text="0"
                               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="salaires" style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
                    </VBox>

                    <VBox GridPane.columnIndex="1" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="💰 Salaire moyen" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                        <Label fx:id="lblAverage" text="0 TND"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4299e1;"/>
                    </VBox>

                    <VBox GridPane.columnIndex="2" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="💵 Total versé" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                        <Label fx:id="lblTotal" text="0 TND"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #48bb78;"/>
                    </VBox>

                    <VBox GridPane.columnIndex="3" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="✅ Salaires payés" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                        <Label fx:id="lblPaidPercentage" text="0%"
                               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #9f7aea;"/>
                    </VBox>
                </GridPane>

                <!-- GRAPHIQUES -->
                <HBox spacing="20">
                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="📈 Salaires par Employé"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <ImageView fx:id="imgBarChart" preserveRatio="true" fitWidth="550"/>
                    </VBox>

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="🥧 Répartition par Statut"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <ImageView fx:id="imgPieChart" preserveRatio="true" fitWidth="400"/>
                    </VBox>
                </HBox>

                <!-- PRÉDICTION IA -->
                <VBox spacing="15"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🤖 Prédiction IA des Salaires"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="(Algorithme de Régression Linéaire)"
                               style="-fx-font-size: 11px; -fx-text-fill: #718096; -fx-font-style: italic;"/>
                    </HBox>

                    <ImageView fx:id="imgPredictionChart" preserveRatio="true" fitWidth="900"/>

                    <HBox spacing="20">
                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #f0f9ff; -fx-padding: 15; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-color: #4299e1; -fx-border-width: 2;">
                            <Label text="📈 Prédictions des 3 prochains mois :"
                                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #2d3748;"/>
                            <Label fx:id="lblPrediction1" text="..."
                                   style="-fx-font-size: 12px; -fx-text-fill: #4a5568;"/>
                            <Label fx:id="lblPrediction2" text="..."
                                   style="-fx-font-size: 12px; -fx-text-fill: #4a5568;"/>
                            <Label fx:id="lblPrediction3" text="..."
                                   style="-fx-font-size: 12px; -fx-text-fill: #4a5568;"/>
                        </VBox>

                        <VBox spacing="8" alignment="CENTER_LEFT"
                              style="-fx-background-color: #f0fdf4; -fx-padding: 15; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-color: #10b981; -fx-border-width: 2;">
                            <Label text="📊 Qualité de la prédiction :"
                                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #2d3748;"/>
                            <Label fx:id="lblConfidence" text="..."
                                   style="-fx-font-size: 13px;"/>
                            <Label text="• Sup à 70% = Excellente"
                                   style="-fx-font-size: 10px; -fx-text-fill: #10b981;"/>
                            <Label text="• 50-70% = Modérée"
                                   style="-fx-font-size: 10px; -fx-text-fill: #f59e0b;"/>
                            <Label text="• Inf à 50% = Insuffisante"
                                   style="-fx-font-size: 10px; -fx-text-fill: #ef4444;"/>
                        </VBox>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>

    </VBox>

</AnchorPane>